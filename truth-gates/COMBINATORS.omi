# [Combinator 0x08]: Diagonal Separation
omi-0000-0000-0000-0000-0000-000f-b008/128 COMBINE diagonal-separation

omi-
  (
    (input . nibble-state-0xF)
    (diagonals .
      ((D+ . "{0,5,A,F}")
       (D- . "{3,6,9,C}")))
    (form .
      ((D+-sum . "0+5+A+F = 0x1E")
       (D--sum . "3+6+9+C = 0x1E")
       (closure . "0x1E + 0x1E = 0x3C = 60")))
    (output .
      (even-branch-D+
       odd-branch-D-
       sexagesimal-gate-60))
    (property .
      (diagonal-sum-is-invariant-under-permutation
       branches-mirror-each-other
       each-branch-preserves-parity))
  )
-imo
