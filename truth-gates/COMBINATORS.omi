# [Combinator 0x01]: Delta Motion
omi-0000-0000-5a3c-0000-0000-0000-0000-b001/128 COMBINE delta-motion

omi-
  (
    (input . ((x . uint16) (C . 0x5A3C)))
    (form . "Δ_C(x) = rotl(x,1) ⊕ rotl(x,3) ⊕ rotr(x,2) ⊕ C")
    (output . "x':uint16")
    (property .
      (rotations-preserve-bits
       xor-preserves-reversibility
       constant-breaks-zero-fixed-point
       mask-preserves-boundedness))
  )
-imo

# [Combinator 0x02]: Quadratic Projection
omi-0000-0000-0000-0000-0000-0000-0078-b002/128 COMBINE quadratic-projection

omi-
  (
    (input . ((x . 0..3) (y . 0..3)))
    (form . "Q_xy(x,y) = 60x² + 16xy + 4y²")
    (output .
      ((q . Q_xy)
       (local240 . "q mod 240")
       (zRoot . "q / 6")))
    (property .
      ("Q_xy(3,3)=720"
       "Q_xy(3,3)/6=120"
       "local240 ∈ 0..239"))
  )
-imo

